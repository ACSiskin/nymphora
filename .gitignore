# =========================================================
# NYMPHORA .gitignore
# =========================================================

# --- dependencies ---
node_modules/

# --- Next.js build output ---
.next/
out/
dist/
build/

# --- Vercel / Turbo ---
.vercel/
.turbo/

# --- logs ---
*.log
logs/

# --- env (secrets) ---
.env
.env.*
!.env.example

# --- caches ---
.cache/
.tmp/
tmp/
temp/

# --- test / coverage ---
coverage/
.nyc_output/
playwright-report/
test-results/

# --- OS / editors ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# --- Prisma local DB artifacts (keep schema/migrations) ---
prisma/*.db
prisma/*.db-journal

# --- Python (if Nova backend exists) ---
__pycache__/
*.py[cod]
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
